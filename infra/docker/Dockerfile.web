# ── Stage 1: deps ─────────────────────────────────────────────
FROM node:22-alpine AS deps
WORKDIR /app
COPY package*.json ./
RUN npm ci

# ── Stage 2: build ────────────────────────────────────────────
FROM node:22-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npm run build

# ── Stage 3: runner ───────────────────────────────────────────
FROM node:22-alpine AS runner

RUN addgroup -S zimrecruit && adduser -S zimrecruit -G zimrecruit

WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

COPY --from=builder --chown=zimrecruit:zimrecruit /app/public ./public
COPY --from=builder --chown=zimrecruit:zimrecruit /app/.next/standalone ./
COPY --from=builder --chown=zimrecruit:zimrecruit /app/.next/static ./.next/static

USER zimrecruit
EXPOSE 3000
CMD ["node", "server.js"]
