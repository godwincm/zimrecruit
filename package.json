{
  "name": "zimrecruit",
  "version": "1.0.0",
  "private": true,
  "description": "Supabase-backed recruitment and credential verification platform for Zimbabwe",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "build": "npm run build -w apps/api && npm run build -w apps/web",
    "lint": "eslint \"apps/*/src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit -p apps/api/tsconfig.json && tsc --noEmit -p apps/web/tsconfig.json",
    "test": "vitest run",
    "seed:admin": "npm run seed:admin -w apps/api",
    "db:check": "npm run db:check -w apps/api",
    "migrate": "psql \"$SUPABASE_DB_URL\" -f supabase/migrations/0001_initial.sql",
    "db:schema": "psql \"$SUPABASE_DB_URL\" -f supabase/migrations/0001_initial.sql"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2"
  }
}
