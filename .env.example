# Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=zimrecruit
MYSQL_USER=zimrecruit
MYSQL_PASSWORD=zimrecruitsecret
MYSQL_ROOT_PASSWORD=rootsecret
MYSQL_SSL=false

# Redis
REDIS_URL=redis://:redissecret@localhost:6379
REDIS_PASSWORD=redissecret

# Appwrite
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-project-id
APPWRITE_API_KEY=your-server-api-key
APPWRITE_BUCKET_MEDIA=zimrecruit-media

# JWT (RS256)
JWT_PRIVATE_KEY_PEM=$(cat private.pem)
JWT_PUBLIC_KEY_PEM=$(cat pub.pem)
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Email
# Email delivery uses Appwrite Messaging. Configure the email provider in Appwrite Console.

# Mockchain / ngrok only
# This app only supports the local Hardhat mockchain.
# Use the ngrok tunnel forwarding to the local mockchain on port 8545.
BLOCKCHAIN_RPC_URL=https://skirmish-thicken-derived.ngrok-free.dev
BLOCKCHAIN_CHAIN_ID=31337
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
VERIFIER_PRIVATE_KEY=your-mockchain-verifier-private-key
VERIFIER_WALLET_ADDRESS=0xyourmockchainverifierwallet000000000000000000
PLATFORM_ADMIN_ADDRESS=0xyourmockchainadminwallet000000000000000000000
GAS_LIMIT=250000

# Application
APP_BASE_URL=http://localhost:3000
NODE_ENV=development
PORT=4000
NEXT_PUBLIC_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your-project-id
NEXT_PUBLIC_APPWRITE_BUCKET_ID=zimrecruit-media
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your-project-id
VITE_APPWRITE_BUCKET_ID=zimrecruit-media
REACT_APP_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
REACT_APP_APPWRITE_PROJECT_ID=your-project-id
REACT_APP_APPWRITE_BUCKET_ID=zimrecruit-media

# Admin Seed
ADMIN_APPWRITE_USER_ID=
ADMIN_EMAIL=
ADMIN_FULL_NAME=
ADMIN_PASSWORD=
